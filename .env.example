# Clés API de la couche IA (toutes optionnelles).
# Sans aucune clé, le prototype fonctionne en repli simulé déterministe (badge « Démo »).
# Avec au moins une clé, il fait de vrais appels IA (badge « IA »), dans cet ordre de bascule :
# Mistral (FR/UE, RGPD) -> Groq (repli rapide) -> Gemini.
#
# Copier ce fichier en .env.local et renseigner les clés voulues. Ne JAMAIS committer .env.local.

# Mistral AI — La Plateforme (recommandé : éditeur FR/UE, API no-training par défaut)
# Clé : https://console.mistral.ai/
MISTRAL_API_KEY=
# MISTRAL_MODEL=mistral-large-latest

# Groq (repli, free tier permanent, OpenAI-compatible)
# Clé : https://console.groq.com/
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (dernier repli)
# Clé : https://aistudio.google.com/
GOOGLE_API_KEY=
# GOOGLE_MODEL=gemini-2.0-flash
